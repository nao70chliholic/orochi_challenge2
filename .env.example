# Discord Token (Get it from Discord Developer Portal -> Bot -> Token)
DISCORD_BOT_TOKEN="your_discord_bot_token"

# Discord Application Client ID (Get it from Discord Developer Portal -> General Information -> Application ID)
DISCORD_CLIENT_ID="your_discord_client_id"

# The Guild ID where you want to test the bot commands (Enable Developer Mode in Discord Advanced Settings to copy Server ID)
DISCORD_GUILD_ID="your_guild_id"

# The Channel ID where the bot should send the 7:30 daily post
TARGET_CHANNEL_ID="your_channel_id"

# Timezone for the Cron job
TIMEZONE="Asia/Tokyo"

# Database URL for Prisma local SQLite
DATABASE_URL="file:./dev.db"
